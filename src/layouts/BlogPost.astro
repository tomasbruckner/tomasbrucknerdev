---
import { render } from 'astro:content';
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import { useTranslations, type Lang } from '../i18n/util';
import { blogUrl, type BlogPost as BlogPostEntry } from '../lib/blog';
import { formatDate } from '../lib/format';
import { SITE_URL } from '../consts';

interface Props { lang: Lang; post: BlogPostEntry }
const { lang, post } = Astro.props;
const t = useTranslations(lang);
const { Content, remarkPluginFrontmatter } = await render(post);

const postLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: { '@type': 'Person', name: 'Tomáš Bruckner', url: SITE_URL },
  inLanguage: lang === 'cs' ? 'cs-CZ' : 'en-US',
  mainEntityOfPage: new URL(Astro.url.pathname, SITE_URL).href,
  image: new URL('/og-image.png', SITE_URL).href,
};
---
<Base lang={lang} title={post.data.title + ' — Tomáš Bruckner'} description={post.data.description} ogType="article">
  <Nav lang={lang} />
  <main id="main" class="mx-auto max-w-3xl px-4">
    <article class="prose prose-zinc max-w-none py-16 dark:prose-invert prose-img:rounded-xl prose-pre:overflow-x-auto">
      <h1 class="not-prose text-3xl font-bold tracking-tight sm:text-4xl">{post.data.title}</h1>
      <div class="not-prose mt-4 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-zinc-500 dark:text-zinc-400">
        <span>
          {t.blog.published}
          {' '}
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
        </span>
        <span aria-hidden="true">·</span>
        <span>{remarkPluginFrontmatter.minutesRead} {t.blog.readingTime}</span>
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <a
              href={blogUrl(lang, 'tag/' + tag + '/')}
              class="rounded-full border border-zinc-300 px-2.5 py-0.5 text-xs text-zinc-600 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] dark:border-zinc-700 dark:text-zinc-300"
            >
              {tag}
            </a>
          ))}
        </div>
      </div>

      <div class="mt-10">
        <Content />
      </div>

      <a href={blogUrl(lang)} class="not-prose mt-12 inline-block text-[var(--color-accent)] hover:underline">
        ← {t.blog.backToBlog}
      </a>
    </article>
  </main>
  <Footer lang={lang} />
  <JsonLd data={postLd} />
</Base>
