---
import { render } from 'astro:content';
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import TagList from '../components/TagList.astro';
import { useTranslations, type Lang } from '../i18n/util';
import { blogUrl, type BlogPost as BlogPostEntry } from '../lib/blog';
import { formatDate, localeCode } from '../lib/format';
import { SITE_URL, SITE_NAME } from '../consts';

interface Props { lang: Lang; post: BlogPostEntry }
const { lang, post } = Astro.props;
const t = useTranslations(lang);
const { Content, remarkPluginFrontmatter } = await render(post);

const postLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  author: { '@type': 'Person', name: SITE_NAME, url: SITE_URL },
  inLanguage: localeCode(lang),
  mainEntityOfPage: new URL(Astro.url.pathname, SITE_URL).href,
  image: new URL('/og-image.png', SITE_URL).href,
};

const article = {
  publishedTime: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { modifiedTime: post.data.updatedDate.toISOString() }),
  tags: post.data.tags,
};
---
<Base
  lang={lang}
  title={`${post.data.title} — ${SITE_NAME}`}
  description={post.data.description}
  ogType="article"
  article={article}
>
  <Nav lang={lang} />
  <main id="main" class="mx-auto max-w-3xl px-4">
    <article class="prose prose-zinc max-w-none py-16 dark:prose-invert prose-img:rounded-xl prose-pre:overflow-x-auto">
      <h1 class="not-prose text-3xl font-bold tracking-tight sm:text-4xl">{post.data.title}</h1>
      <div class="not-prose mt-4 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-zinc-500 dark:text-zinc-400">
        <span>
          {t.blog.published}
          {' '}
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time>
        </span>
        <span aria-hidden="true">·</span>
        <span>{remarkPluginFrontmatter.minutesRead} {t.blog.readingTime}</span>
        <div class="flex flex-wrap gap-2">
          <TagList tags={post.data.tags} lang={lang} />
        </div>
      </div>

      <div class="mt-10">
        <Content />
      </div>

      <a href={blogUrl(lang)} class="not-prose mt-12 inline-block text-[var(--color-accent)] hover:underline">
        ← {t.blog.backToBlog}
      </a>
    </article>
  </main>
  <Footer lang={lang} />
  <JsonLd data={postLd} />
</Base>
