---
import { useTranslations, type Lang } from '../i18n/util';
import { EMAIL } from '../consts';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<button
  type="button"
  id="copy-email"
  data-email={EMAIL}
  data-copy={t.contact.copy}
  data-copied={t.contact.copied}
  class="rounded-md border border-zinc-300 px-3 py-1 text-sm hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-800"
>
  {t.contact.copy}
</button>

<script>
  const btn = document.getElementById('copy-email') as HTMLButtonElement | null;
  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(btn.dataset.email ?? '');
      const original = btn.dataset.copy ?? '';
      btn.textContent = btn.dataset.copied ?? '';
      setTimeout(() => { btn.textContent = original; }, 1500);
    } catch {
      /* clipboard unavailable — leave the label unchanged */
    }
  });
</script>
