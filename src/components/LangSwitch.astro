---
import { useTranslations, getAltLangUrl, type Lang } from '../i18n/util';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<a
  href={getAltLangUrl(lang)}
  aria-label={t.langSwitch.label}
  class="rounded-md border border-zinc-300 px-2 py-1 text-sm text-zinc-700 hover:bg-zinc-100 dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-800"
>
  {t.langSwitch.short}
</a>
