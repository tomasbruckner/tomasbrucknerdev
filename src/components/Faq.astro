---
import { useTranslations, type Lang } from '../i18n/util';
import { FAQ_ITEMS } from '../data/faq';
import JsonLd from './JsonLd.astro';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((k) => ({
    '@type': 'Question',
    name: t.faqItems[k].q,
    acceptedAnswer: { '@type': 'Answer', text: t.faqItems[k].a },
  })),
};
---
<section id="faq" class="scroll-mt-20 py-16">
  <h2 class="mb-8 text-2xl font-bold tracking-tight">{t.faq.heading}</h2>
  <div class="divide-y divide-zinc-200 dark:divide-zinc-800">
    {FAQ_ITEMS.map((k) => (
      <details class="group py-4">
        <summary class="cursor-pointer list-none font-medium marker:content-none">
          <span class="flex items-center justify-between">
            {t.faqItems[k].q}
            <span class="transition group-open:rotate-45" aria-hidden="true">+</span>
          </span>
        </summary>
        <p class="mt-3 leading-relaxed text-zinc-600 dark:text-zinc-400">{t.faqItems[k].a}</p>
      </details>
    ))}
  </div>
  <JsonLd data={faqLd} />
</section>
