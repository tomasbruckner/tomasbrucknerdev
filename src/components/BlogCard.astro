---
import { useTranslations, type Lang } from '../i18n/util';
import { blogUrl, postSlug, type BlogPost } from '../lib/blog';
import { formatDate } from '../lib/format';
import TagList from './TagList.astro';
interface Props { post: BlogPost; lang: Lang; headingLevel?: 'h2' | 'h3' }
const { post, lang, headingLevel: Heading = 'h3' } = Astro.props;
const t = useTranslations(lang);
const frontmatter = post.rendered?.metadata?.frontmatter as { minutesRead?: number } | undefined;
const minutesRead = frontmatter?.minutesRead;
const postUrl = blogUrl(lang, postSlug(post) + '/');
---
<article class="overflow-hidden rounded-xl border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">
  <time datetime={post.data.pubDate.toISOString()} class="block text-sm text-zinc-500 dark:text-zinc-400">
    {formatDate(post.data.pubDate, lang)}
  </time>
  <Heading class="mt-2 text-lg font-semibold">
    <a href={postUrl} class="hover:text-[var(--color-accent)]">{post.data.title}</a>
  </Heading>
  <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">{post.data.description}</p>
  {minutesRead && (
    <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-400">
      {minutesRead} {t.blog.readingTime}
    </p>
  )}
  <div class="mt-4 flex flex-wrap gap-2">
    <TagList tags={post.data.tags} lang={lang} />
  </div>
</article>
