---
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import BlogList from '../../../components/BlogList.astro';
import Footer from '../../../components/Footer.astro';
import { useTranslations } from '../../../i18n/util';
import { getTagStaticPaths, type BlogPost } from '../../../lib/blog';
import { SITE_NAME } from '../../../consts';

const lang = 'cs' as const;

interface Props { posts: BlogPost[] }

export async function getStaticPaths() {
  return getTagStaticPaths('cs');
}

const { posts } = Astro.props;
const { tag } = Astro.params as { tag: string };
const t = useTranslations(lang);
const heading = `${t.blog.tagHeading}: ${tag}`;
---
<Base lang={lang} title={`${heading} — ${SITE_NAME}`} description={t.blog.metaDescription}>
  <Nav lang={lang} />
  <main id="main" class="mx-auto max-w-3xl px-4">
    <BlogList lang={lang} posts={posts} heading={heading} />
  </main>
  <Footer lang={lang} />
</Base>
